# Database Configuration
UPSTASH_REDIS_REST_URL=your_upstash_redis_rest_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token
UPSTASH_REDIS_KEY=portfolio:projects:v1
UPSTASH_ANALYTICS_KEY=portfolio:analytics:v1

# Authentication
ADMIN_PASSWORD=your_secure_admin_password
ADMIN_PASSWORD_HASH=your_hashed_password_optional
JWT_SECRET=your_jwt_secret_key
PASSWORD_SALT=your_password_salt

# Media Storage
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your_cloudinary_upload_preset

# Cloudinary Admin API (for deleting media)
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://your-domain.com
NEXT_PUBLIC_BASE_URL=https://your-domain.com

# Error Tracking & Logging
NEXT_PUBLIC_ERROR_TRACKING_ENDPOINT=your_error_tracking_endpoint
NEXT_PUBLIC_LOGGING_ENDPOINT=your_logging_endpoint

# Analytics Configuration
NEXT_PUBLIC_ANALYTICS_ENDPOINT=https://your-analytics-endpoint.com/api/events
NEXT_PUBLIC_ANALYTICS_DEBUG=false
NEXT_PUBLIC_ANALYTICS_ENABLED=true

# Google Analytics (optional)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Sentry Error Tracking (optional)
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_ORG=your-org
SENTRY_PROJECT=your-project
SENTRY_AUTH_TOKEN=your-auth-token

# Performance Monitoring
NEXT_PUBLIC_PERFORMANCE_MONITORING=true
NEXT_PUBLIC_WEB_VITALS_ENDPOINT=https://your-analytics-endpoint.com/api/vitals

# Feature Flags
NEXT_PUBLIC_ENABLE_MONITORING_DASHBOARD=true
NEXT_PUBLIC_ENABLE_ERROR_REPORTING=true
NEXT_PUBLIC_ENABLE_PERFORMANCE_TRACKING=true

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Security
CSRF_SECRET=your-csrf-secret-key
SESSION_SECRET=your-session-secret-key

# Development
NODE_ENV=development
